{
  "name": "pocketdev-execution-server",
  "version": "1.0.0",
  "description": "PocketDev IDE - Secure code execution + dev server proxy backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
